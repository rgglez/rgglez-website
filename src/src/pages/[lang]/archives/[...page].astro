---
export const prerender = true;
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import PostsListLayout from "@/layouts/PostsListLayout.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getPostsByGroupCondition from "@/utils/getPostsByGroupCondition";
import getTagsWithCount from "@/utils/getTagsWithCount";
import getSortedPosts from "@/utils/getSortedPosts";
import { getFileLang } from "@/utils/getTranslations";
import { getMonthName } from "@/utils/formatDate";
import { SITE } from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  return SITE.supportedLangs.flatMap(lang => {
    const langPosts = getSortedPosts(allPosts).filter(
      post => getFileLang(post.filePath) === lang
    );
    return paginate(langPosts, { params: { lang }, pageSize: 10 });
  });
}) satisfies GetStaticPaths;

if (!SITE.showArchives) {
  return Astro.redirect("/404");
}

const { page } = Astro.props;
const { lang } = Astro.params;
const allPosts = await getCollection("blog");

const langPosts = allPosts.filter(post => getFileLang(post.filePath) === lang);
const tagCloudTags = getTagsWithCount(langPosts).map(({ tag, tagName, count }) => ({
  label: tagName,
  href: `/${lang}/tags/${tag}/`,
  count,
}));
---

<PostsListLayout
  title={`Blog | ${SITE.title}`}
  pageTitle="Archive"
  pageDesc="All the articles I've archived."
  {tagCloudTags}
  showTagCloud={true}
  posts={allPosts}
  {lang}
  noMarginTop={page.lastPage > 1}
>
  {
    Object.entries(
      getPostsByGroupCondition(page.data, post =>
        post.data.pubDatetime.getFullYear()
      )
    )
      .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
      .map(([year, yearGroup]) => (
        <div>
          <span class="text-2xl font-bold">{year}</span>
          <sup class="text-sm">{yearGroup.length}</sup>
          {Object.entries(
            getPostsByGroupCondition(
              yearGroup,
              post => post.data.pubDatetime.getMonth() + 1
            )
          )
            .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
            .map(([month, monthGroup]) => (
              <div class="flex flex-col sm:flex-row">
                <div class="mt-6 min-w-36 text-lg sm:my-6">
                  <span class="font-bold">{getMonthName(Number(month) - 1, lang)}</span>
                  <sup class="text-xs">{monthGroup.length}</sup>
                </div>
                <ul>
                  {monthGroup
                    .sort(
                      (a, b) =>
                        Math.floor(new Date(b.data.pubDatetime).getTime() / 1000) -
                        Math.floor(new Date(a.data.pubDatetime).getTime() / 1000)
                    )
                    .map(data => (
                      <Card {...data} allPosts={allPosts} />
                    ))}
                </ul>
              </div>
            ))}
        </div>
      ))
  }

  <Pagination {page} slot="pagination" />
</PostsListLayout>
