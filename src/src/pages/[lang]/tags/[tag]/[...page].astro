---
export const prerender = true;
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import PostsListLayout from "@/layouts/PostsListLayout.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import getTagsWithCount from "@/utils/getTagsWithCount";
import { getFileLang } from "@/utils/getTranslations";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const tags = getUniqueTags(posts);

  return SITE.supportedLangs.flatMap(lang =>
    tags.flatMap(({ tag, tagName }) => {
      const tagPosts = getPostsByTag(posts, tag).filter(
        post => getFileLang(post.filePath) === lang
      );
      if (tagPosts.length === 0) return [];
      return paginate(tagPosts, {
        params: { lang, tag },
        props: { tagName },
        pageSize: SITE.postPerPage,
      });
    })
  );
}

const { tag, lang } = Astro.params;
const { page, tagName } = Astro.props;
const allPosts = await getCollection("blog");

const langPosts = allPosts.filter(post => getFileLang(post.filePath) === lang);
const tagCloudTags = getTagsWithCount(langPosts).map(({ tag: t, tagName: tn, count }) => ({
  label: tn,
  href: `/${lang}/tags/${t}/`,
  count,
}));
---

<PostsListLayout
  title={`Tag: ${tagName} | ${SITE.title}`}
  pageTitle={`Tag: ${tagName}`}
  pageDesc={`All the articles with the tag "${tagName}".`}
  {tagCloudTags}
  showTagCloud={true}
  posts={allPosts}
  {lang}
  noMarginTop={page.lastPage > 1}
>
  <ul>
    {page.data.map(data => <Card {...data} allPosts={allPosts} />)}
  </ul>

  <Pagination {page} slot="pagination" />
</PostsListLayout>
