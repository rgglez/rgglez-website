---
export const prerender = true;
import { SITE } from "@/config";
const { supportedLangs, defaultLang } = SITE;
const defaultUrl = new URL(`/${defaultLang}/`, SITE.website).href;
const ogImageUrl = new URL(SITE.ogImage, SITE.website).href;
---
<html>
  <head>
    <meta charset="UTF-8" />
    <link rel="canonical" href={defaultUrl} />
    <meta http-equiv="refresh" content={`0;url=${defaultUrl}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={SITE.title} />
    <meta property="og:description" content={SITE.desc} />
    <meta property="og:url" content={SITE.website} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={SITE.title} />
    <meta property="twitter:description" content={SITE.desc} />
    <meta property="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <script is:inline define:vars={{ supportedLangs, defaultLang }}>
      const lang = (navigator.language ?? "").split("-")[0].toLowerCase();
      const target = supportedLangs.includes(lang) ? lang : defaultLang;
      window.location.pathname = `/${target}/`;
    </script>
  </body>
</html>
