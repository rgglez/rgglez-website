---
interface TagItem {
  label: string;
  href?: string;
  count?: number;
}

interface Props {
  tags: TagItem[];
}

const { tags } = Astro.props;
---

<details class="tag-list" open>
  <summary class="tag-list-summary">
    <span class="arrow">▶</span>
    <span class="summary-label">Browse tags</span>
  </summary>
  <div class="tag-list-body">
    <input
      type="search"
      class="tag-filter"
      placeholder="Filter…"
      aria-label="Filter tags"
      autocomplete="off"
    />
    <ul class="tag-entries">
      {
        tags.map(({ label, href, count }) => (
          <li data-tag-label={label.toLowerCase()}>
            <a href={href ?? "#"}>{label}</a>
            {count !== undefined && <span class="tag-count">{count}</span>}
          </li>
        ))
      }
    </ul>
  </div>
</details>

<script>
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLElement>(".tag-list").forEach(root => {
      const input = root.querySelector<HTMLInputElement>(".tag-filter");
      const items = Array.from(root.querySelectorAll<HTMLElement>("li[data-tag-label]"));
      if (!input) return;
      input.addEventListener("input", () => {
        const q = input.value.toLowerCase().trim();
        items.forEach(li => {
          li.style.display = !q || li.dataset.tagLabel!.includes(q) ? "" : "none";
        });
      });
    });
  });
</script>

<style>
  .tag-list {
    margin-top: 0.75rem;
  }

  .tag-list-summary {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
    padding: 0.25rem 0.35rem;
    border-radius: 0.25rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--foreground);
    user-select: none;
  }

  .tag-list-summary::-webkit-details-marker {
    display: none;
  }

  .tag-list-summary:hover {
    background-color: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }

  .arrow {
    display: inline-block;
    font-size: 0.55rem;
    color: var(--accent);
    transition: transform 0.15s ease;
    transform: rotate(0deg);
    line-height: 1;
  }

  details[open] > .tag-list-summary .arrow {
    transform: rotate(90deg);
  }

  .tag-list-body {
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .tag-filter {
    width: 100%;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--foreground);
    font-size: 0.8rem;
    outline: none;
  }

  .tag-filter:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .tag-entries {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 18rem;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .tag-entries li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.2rem 0.35rem;
    border-radius: 0.25rem;
    gap: 0.5rem;
  }

  .tag-entries li:hover {
    background-color: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .tag-entries a {
    color: var(--foreground);
    text-decoration: none;
    font-size: 0.82rem;
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tag-entries a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .tag-count {
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    flex-shrink: 0;
  }
</style>
