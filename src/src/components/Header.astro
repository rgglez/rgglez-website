---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconLinkedin from "@/assets/icons/IconLinkedin.svg";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import IconWorld from "@/assets/icons/IconWorld.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import 'flag-icons/css/flag-icons.min.css'

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

// Derive current lang from URL first segment, fallback to default
const currentLang =
  currentPath.split("/").filter(Boolean)[0] ?? SITE.defaultLang;

const langNames: Record<string, Record<string, string>> = {
  es: {
    icon: "fi fi-es",
    text: "Español",
  },
  en: {
    icon: "fi fi-us",
    text: "English",
  },
  fr: {
    icon: "fi fi-fr",
    text: "Français",
  }
};

// Compare second segment (index 1) after lang prefix
const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[1] === pathArray[1];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href="/"
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
        {SITE.title}
    </a>
    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
    >
      <button
        id="menu-btn"
        class="focus-outline self-end p-2 sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="menu-items"
      >
        <IconX id="close-icon" class="hidden" />
        <IconMenuDeep id="menu-icon" />
      </button>
      <ul
        id="menu-items"
        class:list={[
          "mt-4 grid w-44 grid-cols-2 place-content-center gap-2",
          "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          "hidden",
          "sm:mt-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0",
        ]}
      >
        <li class="col-span-2">
          <a href={`/${currentLang}/posts`} class:list={{ "active-nav": isActive(`/${currentLang}/posts`) }}>
            Blog
          </a>
        </li>
        {
          SITE.showArchives && (
            <li class="col-span-2">
              <LinkButton
                href={`/${currentLang}/archives`}
                class:list={[
                  "focus-outline flex justify-center p-3 sm:p-1",
                  {
                    "active-nav [&>svg]:stroke-accent": isActive(`/${currentLang}/archives`),
                  },
                ]}
                title="Archives"
                aria-label="archives"
              >
                <IconArchive class="hidden sm:inline-block" />
                <span class="sm:sr-only">Archives</span>
              </LinkButton>
            </li>
          )
        }
        <li class="col-span-1 flex items-center justify-center">
          <LinkButton
            href="/search"
            class:list={[
              "focus-outline flex p-3 sm:p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Search"
            aria-label="search"
          >
            <IconSearch />
            <span class="sr-only">Search</span>
          </LinkButton>
        </li>
        <li class="col-span-1 flex items-center justify-center">
            <a
                target="_blank"
                href="/rss.xml"
                class="inline-block"
                aria-label="rss feed"
                title="RSS Feed"
            >
                <IconRss
                width={16}
                height={16}
                class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
                />
                <span class="sr-only">Linkedin</span>
            </a>
        </li>
        <li class="col-span-1 flex items-center justify-center">
            <a
                target="_blank"
                href="https://github.com/rgglez"
                class="inline-block"
                aria-label="github.com/rgglez"
                title="github.com/rgglez"
            >
                <IconGitHub/>
                <span class="sr-only">RSS Feed</span>
            </a>
        </li>
        <li class="col-span-1 flex items-center justify-center">
            <a
                target="_blank"
                href="https://linkedin.com/in/rggonzalez"
                class="inline-block"
                aria-label="linkedin.com/in/rggonzalez"
                title="linkedin.com/in/rggonzalez"
            >
                <IconLinkedin/>
                <span class="sr-only">RSS Feed</span>
            </a>
        </li>
        <li class="col-span-1 relative flex items-center justify-center">
          <button
            id="lang-btn"
            class="focus-outline flex p-3 sm:p-1 hover:[&>svg]:stroke-accent"
            aria-label="Change language"
            title="Change language"
            aria-expanded="false"
            aria-haspopup="true"
          >
            <IconWorld />
            <span class="sr-only">Change language</span>
          </button>
          <ul
            id="lang-menu"
            class="absolute top-full right-0 z-50 hidden mt-1 min-w-max rounded border border-border bg-background shadow-lg"
          >
            {SITE.supportedLangs.map(lang => (
              <li>
                <a
                  href={`/${lang}/`}
                  class="block px-4 py-2 text-sm hover:text-accent hover:bg-accent/10"
                >
                  <span class={langNames[lang].icon} />
                  {langNames[lang].text ?? lang.toUpperCase()}
                </a>
              </li>
            ))}
          </ul>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li class="col-span-1 flex items-center justify-center">
              <button
                id="theme-btn"
                class="focus-outline relative size-12 p-4 sm:size-8 hover:[&>svg]:stroke-accent"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
              </button>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  function toggleLangMenu() {
    const langBtn = document.querySelector("#lang-btn");
    const langMenu = document.querySelector("#lang-menu");
    if (!langBtn || !langMenu) return;

    langBtn.addEventListener("click", e => {
      e.stopPropagation();
      const isOpen = langBtn.getAttribute("aria-expanded") === "true";
      langBtn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      langMenu.classList.toggle("hidden", isOpen);
    });

    document.addEventListener("click", () => {
      langBtn.setAttribute("aria-expanded", "false");
      langMenu.classList.add("hidden");
    });
  }

  toggleLangMenu();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", () => {
    toggleNav();
    toggleLangMenu();
  });
</script>
