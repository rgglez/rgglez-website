---
import IconWorld from "@/assets/icons/IconWorld.svg";
import { SITE } from "@/config";
import { LANG_NAMES } from "@/utils/langNames";
import 'flag-icons/css/flag-icons.min.css';

const { pathname } = Astro.url;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const currentLang =
  currentPath.split("/").filter(Boolean)[0] ?? SITE.defaultLang;

const langIcons: Record<string, string> = {
  es: "fi fi-es",
  en: "fi fi-us",
  fr: "fi fi-fr",
  de: "fi fi-de",
};
---

<li class="col-span-1 relative flex items-center justify-center">
  <button
    id="lang-btn"
    class="focus-outline flex p-3 sm:p-1 hover:[&>svg]:stroke-accent"
    aria-label="Change language"
    title="Change language"
    aria-expanded="false"
    aria-haspopup="true"
  >
    <IconWorld />
    <span class="sr-only">Change language</span>
  </button>
  <ul
    id="lang-menu"
    class="absolute top-full right-0 z-50 hidden mt-1 min-w-max rounded border border-border bg-background shadow-lg"
  >
    {SITE.supportedLangs.map(lang => (
      <li>
        <a
          href={`/${lang}/`}
          class:list={[
            "block px-4 py-2 text-sm hover:text-accent hover:bg-accent/10",
            { "text-accent font-semibold": lang === currentLang },
          ]}
        >
          <span class={langIcons[lang] ?? "fi fi-un"} />
          {LANG_NAMES[lang] ?? lang.toUpperCase()}
        </a>
      </li>
    ))}
  </ul>
</li>

<script>
  function initLangMenu() {
    const langBtn = document.querySelector("#lang-btn");
    const langMenu = document.querySelector("#lang-menu");
    if (!langBtn || !langMenu) return;

    langBtn.addEventListener("click", e => {
      e.stopPropagation();
      const isOpen = langBtn.getAttribute("aria-expanded") === "true";
      langBtn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      langMenu.classList.toggle("hidden", isOpen);
    });

    document.addEventListener("click", () => {
      langBtn.setAttribute("aria-expanded", "false");
      langMenu.classList.add("hidden");
    });
  }

  initLangMenu();
  document.addEventListener("astro:after-swap", initLangMenu);
</script>
