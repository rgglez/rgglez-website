---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { getTranslations, getTranslationKey } from "@/utils/getTranslations";
import Datetime from "./Datetime.astro";
import { SITE } from "@/config";

type Props = {
  variant?: "h2" | "h3";
  allPosts?: CollectionEntry<"blog">[];
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath, allPosts } = Astro.props;

const { title, description, ...props } = data;

const postLangParts = (filePath ?? "").split("/");
const postLang = postLangParts[postLangParts.length - 2] ?? SITE.lang;
const articleKey = getTranslationKey(filePath);

/* ========== Language Translations ========== */

const translations = allPosts ? getTranslations(Astro.props, allPosts) : [];
---

<li class="my-6 flex flex-col" data-lang={postLang} data-article-key={articleKey}>
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block text-lg font-medium text-accent",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <div class="flex items-center gap-2">
    <Datetime {...props} lang={postLang} />
  </div>
  <p class="flex-1">{description}</p>
  {
    translations.length > 1 && (
      <div class="flex justify-start gap-1 mt-1">
        {translations.map(({ lang, href, isCurrent }) =>
          isCurrent ? (
            <span class="rounded border border-accent px-1.5 py-0.5 text-xs font-medium text-accent">
              {lang}
            </span>
          ) : (
            <a
              href={href}
              class="rounded border border-border px-1.5 py-0.5 text-xs text-foreground/70 hover:border-accent hover:text-accent"
              hreflang={lang}
            >
              {lang}
            </a>
          )
        )}
      </div>
    )
  }
</li>
