---
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import { getFileLang, getTranslationKey } from "@/utils/getTranslations";
import { SITE } from "@/config";

interface Props {
  posts: CollectionEntry<"blog">[];
  maxTitleLength?: number;
}

const { posts, maxTitleLength = 48 } = Astro.props;
const { supportedLangs, defaultLang } = SITE;

function truncate(text: string, max: number): string {
  if (text.length <= max) return text;
  const sub = text.slice(0, max);
  const lastSpace = sub.lastIndexOf(" ");
  return (lastSpace > 0 ? sub.slice(0, lastSpace) : sub) + "…";
}

const MONTHS = [
  "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
  "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre",
];

type PostLeaf = { title: string; href: string; lang: string; articleKey: string };

const grouped = new Map<number, Map<number, PostLeaf[]>>();

for (const post of posts) {
  if (post.data.draft) continue;
  const date = new Date(post.data.pubDatetime);
  const year = date.getFullYear();
  const month = date.getMonth();

  if (!grouped.has(year)) grouped.set(year, new Map());
  const byMonth = grouped.get(year)!;
  if (!byMonth.has(month)) byMonth.set(month, []);
  byMonth.get(month)!.push({
    title: truncate(post.data.title, maxTitleLength),
    href: getPath(post.id, post.filePath),
    lang: getFileLang(post.filePath),
    articleKey: getTranslationKey(post.filePath),
  });
}

const currentYear = new Date().getFullYear();
const years = [...grouped.entries()].sort(([a], [b]) => b - a);
---

<div class="posts-tree-wrapper">
  <rux-tree>
    {
      years.map(([year, byMonth]) => {
        const sortedMonths = [...byMonth.entries()].sort(([a], [b]) => b - a);
        return (
          <rux-tree-node expanded={year === currentYear || undefined}>
            {year}
            {sortedMonths.map(([monthIdx, monthPosts]) => (
              <rux-tree-node slot="node">
                {MONTHS[monthIdx]}
                {monthPosts.map(({ title, href, lang, articleKey }) => (
                  <rux-tree-node slot="node" data-lang={lang} data-article-key={articleKey}>
                    <a href={href} class="post-link">
                      {title}
                    </a>
                  </rux-tree-node>
                ))}
              </rux-tree-node>
            ))}
          </rux-tree-node>
        );
      })
    }
  </rux-tree>
</div>

<script
  type="module"
  src="https://cdn.jsdelivr.net/npm/@astrouxds/astro-web-components/dist/astro-web-components/astro-web-components.esm.js"
></script>

<script is:inline define:vars={{ supportedLangs, defaultLang }}>
  document.addEventListener("astro:page-load", () => {
    const browserLang = (navigator.language ?? "").slice(0, 2).toLowerCase();
    const lang = supportedLangs.includes(browserLang) ? browserLang : defaultLang;

    const wrapper = document.querySelector(".posts-tree-wrapper");
    if (!wrapper) return;

    // Group leaf nodes by article key and show only the best language
    const leaves = Array.from(wrapper.querySelectorAll("rux-tree-node[data-lang][data-article-key]"));
    const groups = {};
    leaves.forEach(node => {
      const key = node.dataset.articleKey;
      if (key) {
        if (!groups[key]) groups[key] = [];
        groups[key].push(node);
      }
    });

    Object.values(groups).forEach(group => {
      const best =
        group.find(el => el.dataset.lang === lang) ||
        group.find(el => el.dataset.lang === "en") ||
        group[0];
      group.forEach(el => {
        el.style.display = el === best ? "" : "none";
      });
    });

    // Hide month nodes with no visible leaves
    const monthNodes = Array.from(wrapper.querySelectorAll("rux-tree-node[slot='node']:not([data-lang])"));
    monthNodes.forEach(monthNode => {
      const visibleLeaves = Array.from(monthNode.querySelectorAll("rux-tree-node[data-lang]"))
        .filter(el => el.style.display !== "none");
      monthNode.style.display = visibleLeaves.length > 0 ? "" : "none";
    });

    // Hide year nodes with no visible months
    const yearNodes = Array.from(wrapper.querySelectorAll("rux-tree > rux-tree-node"));
    yearNodes.forEach(yearNode => {
      const visibleMonths = Array.from(yearNode.querySelectorAll("rux-tree-node[slot='node']:not([data-lang])"))
        .filter(el => el.style.display !== "none");
      yearNode.style.display = visibleMonths.length > 0 ? "" : "none";
    });
  });
</script>

<style>
  .posts-tree-wrapper {
    --tree-bg: var(--background);
    --tree-fg: var(--foreground);
    --tree-accent: var(--accent);
    --tree-muted: var(--muted);
    --tree-border: var(--border);

    /* AstroUXDS CSS custom properties override */
    --color-background-base-default: var(--tree-bg);
    --color-background-surface-default: var(--tree-bg);
    --color-background-interactive-default: color-mix(in srgb, var(--tree-accent) 12%, transparent);
    --color-background-interactive-hover: color-mix(in srgb, var(--tree-accent) 18%, transparent);
    --color-text-primary: var(--tree-fg);
    --color-text-interactive-default: var(--tree-accent);
    --color-text-interactive-hover: var(--tree-accent);

    font-family: var(--font-app, inherit);
    display: block;
  }

  /* Shadow part overrides */
  .posts-tree-wrapper rux-tree-node::part(node) {
    background-color: transparent;
    color: var(--tree-fg);
    font-family: inherit;
    border-radius: 0.25rem;
    padding-block: 0.2rem;
  }

  .posts-tree-wrapper rux-tree-node::part(node):hover {
    background-color: color-mix(in srgb, var(--tree-accent) 10%, transparent);
    color: var(--tree-accent);
  }

  .posts-tree-wrapper rux-tree-node::part(indicator) {
    color: var(--tree-accent);
  }

  .posts-tree-wrapper rux-tree-node::part(text) {
    color: inherit;
  }

  /* Post links (leaf nodes) */
  .posts-tree-wrapper .post-link {
    color: inherit;
    text-decoration: none;
  }

  .posts-tree-wrapper .post-link:hover {
    color: var(--tree-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* rux-tree root */
  .posts-tree-wrapper rux-tree {
    width: 100%;
    display: block;
  }
</style>
