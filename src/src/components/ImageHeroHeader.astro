---
import { Image } from "astro:assets";

const { frontmatter, image } = Astro.props;

const heroImage = image;
---

{heroImage && (
    <div class="relative w-full overflow-hidden rounded-t-xl shadow-2xl mb-12 h-[300px] sm:h-[400px] md:h-[500px] lg:h-[600px]">
        <Image
            src={heroImage}
            alt={`${frontmatter.title}`}
            loading="eager"
            fetchpriority="high"
            class="absolute inset-0 w-full h-full object-cover object-center block z-0 border-0"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10 flex items-end">
            <div class="p-6 md:p-10 text-white w-full">
                {/* Opcional: Podrías renderizar el título aquí si Astropaper no lo hiciera */}
            </div>
        </div>
        <div class="absolute inset-x-0 bottom-0 h-3 bg-gradient-to-t from-background to-transparent z-20"></div>
  </div>
)}