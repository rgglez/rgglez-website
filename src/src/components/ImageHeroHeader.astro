---
import { Image } from "astro:assets";

const { frontmatter, image } = Astro.props;

const heroImage = image;
---

{heroImage && (
    <div class="not-prose w-full overflow-hidden rounded-xl mb-4">
        <Image
            src={heroImage}
            alt={`${frontmatter.title}`}
            loading="eager"
            fetchpriority="high"
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, (max-width: 1280px) 896px, 1024px"
            class="w-full h-auto block border-0"
        />
    </div>
)}